{
  "name": "@sv-marker/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "stanza-server:generate": "openapi-typescript ../../openapi/stanza-server/openapi.json -o generated/stanza-server/schema.d.ts",
    "dev": "tsx watch --env-file=.env index.ts",
    "build": "npm run stanza-server:generate && tsc",
    "start": "node dist/index.js",
    "type-check": "npm run stanza-server:generate && tsc --noEmit",
    "clean": "rm -r dist && rm -r generated"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@sv-marker/sentence-structure-document": "^0.1.0",
    "@sv-marker/sentence-structure-document-from-stanza": "^0.1.0",
    "@trpc/server": "^11.16.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
