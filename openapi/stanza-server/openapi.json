              "csubj:pass",
              "dep",
              "det",
              "det:predet",
              "discourse",
              "dislocated",
              "expl",
              "fixed",
              "flat",
              "goeswith",
              "iobj",
              "list",
              "mark",
              "nmod",
              "nmod:desc",
              "nmod:poss",
              "nmod:unmarked",
              "nsubj",
              "nsubj:outer",
              "nsubj:pass",
              "nummod",
              "obj",
              "obl",
              "obl:agent",
              "obl:npmod",
              "obl:tmod",
              "obl:unmarked",
              "orphan",
              "parataxis",
              "punct",
              "reparandum",
              "root",
              "vocative",
              "xcomp"
            ],
            "title": "Deprel"
          }
        },
        "type": "object",
        "required": [
          "id",
          "text",
          "lemma",
          "upos",
          "xpos",
          "feats",
