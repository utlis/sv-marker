              },
              { "type": "string" }
            ],
            "title": "Label"
          },
          "children": {
            "items": { "$ref": "#/components/schemas/StanzaConstituencyNode" },
            "type": "array",
            "title": "Children"
          }
        },
        "type": "object",
        "required": ["label", "children"],
        "title": "StanzaConstituencyNode"
