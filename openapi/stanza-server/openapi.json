        "properties": {
          "text": { "type": "string", "title": "Text" },
          "sentences": {
            "items": { "$ref": "#/components/schemas/StanzaTokenizedSentence" },
            "type": "array",
            "title": "Sentences"
          }
        },
        "type": "object",
